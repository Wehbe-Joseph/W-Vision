# Copy this file to `.env` in this same folder.
#
# DATABASE_URL — copy from Supabase Dashboard → Connect → OR Settings → Database.
# Use the string shown for YOUR use case (do not mix host/port/user from different tabs).
#
# • Direct (IPv6): db.<ref>.supabase.co:5432 — user `postgres`
# • Transaction pooler (IPv4-friendly, good for Drizzle/pg on laptops): often
#   db.<ref>.supabase.co:6543 — user `postgres` (see Connect → "Transaction pooler").
# • Session pooler (older shared pooler): user is `postgres.<ref>` on
#   aws-0-<REGION>.pooler.supabase.com:5432 — region MUST match your project.
#
# If logs show: (ENOTFOUND) tenant/user postgres.<ref> not found — the pooler
# does not recognize that tenant (wrong region host, wrong username, paused
# project, or typo in ref). Fix: open Connect, pick Transaction mode, paste the
# full URI, replace [YOUR-PASSWORD] with your DB password (not the anon JWT).
#
# Drizzle + transaction mode: disable prepared statements if you see
# "prepared statement already exists" (see Supabase pooler docs).
DATABASE_URL=postgresql://postgres:YOUR_DB_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:6543/postgres?sslmode=require
# Project root only — do NOT append /rest/v1/ (Supabase JS adds API paths).
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Use the anon (public) key here - same as in the frontend. Never put service_role in the browser bundle.
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_PUBLIC_KEY
# Service role key for privileged server-side operations (admin auth API, RLS bypass via supabase-js).
# Server-only. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# World Labs (Marble) API key - https://worldlabs.ai/ account / API page
WORLD_LABS_API_KEY=YOUR_WORLDLABS_API_KEY
# Set to false to skip every Marble API call (no credits). Tours still save;
# polling finishes immediately with no 3D embed URL. Default: true.
WORLD_LABS_ENABLED=true

# Resend API key - replace re_xxxxxxxx with your real API key from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxx

# Public base URL the api-server can be reached at (used to hand uploaded
# image URLs to WorldLabs). Change to your deployed origin in production.
PUBLIC_API_BASE_URL=http://localhost:8080

# Supabase Storage: Gaussian splat (.spz) files are uploaded to a public bucket
# named "tours" (paths like tours/{tourId}/{roomKey}.spz). The server creates the
# bucket on boot when SUPABASE_SERVICE_ROLE_KEY is set. Spark loads the public URL.

# Apify API token — needed for /api/scrape-listing. Get it from
# https://console.apify.com/account/integrations
APIFY_TOKEN=apify_api_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional: override the Airbnb scraper actor. Defaults to a public one
# that returns photos + metadata. Format: `username/actor-name`.
APIFY_AIRBNB_ACTOR_ID=tri_angle/new-fast-airbnb-scraper

PORT=8080

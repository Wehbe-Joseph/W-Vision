# Vercel → Project → Settings → Environment Variables
# Apply to Production, Preview, and Development. Redeploy after changes.

# ── Frontend (build-time) ─────────────────────────────────────
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Canonical site URL for OAuth redirects (required for Google sign-in).
VITE_SITE_URL=https://getwvision.com

# Leave empty when API runs on the same Vercel domain (recommended).
# Do NOT set to localhost in production.
# VITE_API_BASE_URL=

# ── API (runtime — serverless /api) ───────────────────────────
DATABASE_URL=postgresql://postgres.YOUR_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?sslmode=require
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=...
APIFY_TOKEN=apify_api_...

# Optional on Vercel — auto-detected from VERCEL_PROJECT_PRODUCTION_URL if unset.
# PUBLIC_API_BASE_URL=https://getwvision.com
TOURVISION_PUBLIC_URL=https://getwvision.com

# Do NOT set PORT on Vercel. Do NOT set localhost URLs in production.

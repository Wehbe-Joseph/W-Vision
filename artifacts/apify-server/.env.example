# --------------------------------------------------------------------
# Apify scraper for Airbnb listings
# --------------------------------------------------------------------
# Easiest setup: paste the full "Run actor synchronously" URL from your
# Apify actor's API tab. It already contains the token in the query
# string, e.g.:
#
#   https://api.apify.com/v2/acts/<ACTOR_ID>/run-sync-get-dataset-items?token=<APIFY_TOKEN>
#
# This is what artifacts/apify-server/index.js reads as APIFY_URL.
APIFY_URL=https://api.apify.com/v2/acts/YOUR_ACTOR_ID/run-sync-get-dataset-items?token=YOUR_APIFY_TOKEN

# Port the apify-server listens on. The frontend calls /apify-server/get-images
# proxied through Vite, so changing this also requires updating the proxy.
PORT=3000

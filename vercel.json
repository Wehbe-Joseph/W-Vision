{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "installCommand": "pnpm install",
  "buildCommand": "pnpm --filter @workspace/tourvision vercel-build",
  "outputDirectory": "artifacts/tourvision/dist/public",
  "rewrites": [
    { "handle": "filesystem" },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/[...slug].js": {
      "maxDuration": 300,
      "memory": 3008,
      "includeFiles": "api/serverless.mjs"
    }
  }
}

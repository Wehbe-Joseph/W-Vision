{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "pnpm install",
  "buildCommand": "pnpm --filter @workspace/api-server build && cp artifacts/api-server/dist/serverless.mjs artifacts/tourvision/api/serverless.mjs && pnpm --filter @workspace/tourvision build",
  "outputDirectory": "artifacts/tourvision/dist/public",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "artifacts/tourvision/api/index.js": {
      "maxDuration": 60,
      "memory": 1024
    }
  }
}

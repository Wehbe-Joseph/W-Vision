{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "pnpm install",
  "buildCommand": "pnpm --filter @workspace/tourvision vercel-build",
  "outputDirectory": "artifacts/tourvision/dist/public",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/[...path].js": {
      "maxDuration": 300,
      "memory": 3008,
      "includeFiles": [
        "api/serverless.mjs",
        "node_modules/sharp/**"
      ]
    }
  }
}

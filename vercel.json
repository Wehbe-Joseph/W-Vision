{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "installCommand": "corepack enable && corepack prepare pnpm@10.18.3 --activate && pnpm install --no-frozen-lockfile",
  "buildCommand": "pnpm --filter @workspace/tourvision vercel-build",
  "builds": [
    {
      "src": "artifacts/tourvision/api/[...slug].js",
      "use": "@vercel/node",
      "config": {
        "maxDuration": 300,
        "memory": 3008,
        "includeFiles": "artifacts/tourvision/api/serverless.mjs"
      }
    },
    {
      "src": "artifacts/tourvision/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "artifacts/tourvision/dist/public"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "artifacts/tourvision/api/[...slug].js"
    },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
